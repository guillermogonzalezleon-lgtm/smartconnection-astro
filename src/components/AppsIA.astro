<section id="apps-ia" class="relative py-24 overflow-hidden bg-dark-bg-2/50">
  <canvas id="aiParticles" class="absolute inset-0 z-0 pointer-events-none"></canvas>
  <div class="blob -right-[100px] top-[10%]"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-accent-gold text-sm font-semibold tracking-widest uppercase">Nuevo</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4">Apps Inteligentes para tu Negocio</h2>
      <p class="text-text-muted max-w-2xl mx-auto leading-relaxed">Desarrollamos aplicaciones a medida potenciadas con Inteligencia Artificial.</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
      {[
        { icon: 'bi-robot', title: 'Claude Code — Desarrollo con IA', desc: 'Utilizamos Claude (Anthropic) para acelerar el desarrollo de software y automatizar procesos.' },
        { icon: 'bi-table', title: 'Airtable — Base de Datos Ágil', desc: 'CRM, gestión de proyectos y bases de datos flexibles para PYMES.' },
        { icon: 'bi-lightning-charge', title: 'AWS Deploy — Alta Performance', desc: 'Desplegamos en Amazon Web Services con arquitectura escalable y segura.' },
        { icon: 'bi-github', title: 'GitHub — CI/CD Profesional', desc: 'Control de versiones, integración continua y deploy automático.' },
        { icon: 'bi-building', title: 'Para Empresas — Enterprise', desc: 'Soluciones SAP + IA para grandes empresas. Automatizaciones corporativas.' },
        { icon: 'bi-person-workspace', title: 'Para PYMES — Accesible', desc: 'Apps a medida que crecen contigo. Sin grandes inversiones iniciales.' },
      ].map(card => (
        <div class="glass-card card-glow p-7 border-accent-gold/10 hover:-translate-y-2 transition-all duration-300 animate-on-scroll">
          <span class="w-12 h-12 rounded-xl bg-accent-gold/10 flex items-center justify-center text-xl text-accent-gold mb-4">
            <i class={`bi ${card.icon}`}></i>
          </span>
          <h3 class="text-white font-bold mb-2">{card.title}</h3>
          <p class="text-text-muted text-sm leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
    <div class="flex flex-wrap justify-center gap-8 animate-on-scroll">
      {['Claude|bi-robot', 'Airtable|bi-table', 'AWS|bi-cloud', 'GitHub|bi-github', 'SAP|bi-hexagon', 'GPT|bi-stars', 'Gemini|bi-gem'].map(item => {
        const [name, icon] = item.split('|');
        return (
          <div class="flex flex-col items-center gap-2 text-text-muted hover:text-primary transition-colors">
            <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center text-2xl border border-white/10">
              <i class={`bi ${icon}`}></i>
            </div>
            <span class="text-xs font-medium">{name}</span>
          </div>
        );
      })}
    </div>
  </div>
</section>
