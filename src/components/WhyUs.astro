<section id="por-que" class="relative py-24 overflow-hidden">
  <div class="blob left-1/2 -top-20 opacity-[0.06]"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16 animate-on-scroll">
      <span class="text-primary text-sm font-semibold tracking-widest uppercase">Nosotros</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mt-3 mb-4">¿Por qué Smart Connection?</h2>
      <p class="text-text-muted max-w-2xl mx-auto leading-relaxed">Empresa chilena de servicios profesionales focalizada en plataformas SAP y desarrollo con IA.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      {[
        { icon: 'bi-bullseye', title: 'Consultores Certificados SAP', desc: 'Equipo de profesionales certificados con amplia experiencia en todo el ecosistema SAP NetWeaver.' },
        { icon: 'bi-rocket-takeoff', title: 'Innovación con IA', desc: 'Pioneros en integrar Claude, GPT y Gemini en soluciones empresariales para Chile y Latinoamérica.' },
        { icon: 'bi-graph-up-arrow', title: 'Resultados Medibles', desc: 'Metodologías ágiles SCRUM y DevOps para mejora continua. Entregamos valor real.' },
      ].map(pillar => (
        <div class="text-center p-8 rounded-2xl bg-dark-bg-2/50 border border-white/5 hover:border-primary/20 transition-all animate-on-scroll">
          <span class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center text-3xl text-primary mx-auto mb-5">
            <i class={`bi ${pillar.icon}`}></i>
          </span>
          <h3 class="text-white font-bold text-xl mb-3">{pillar.title}</h3>
          <p class="text-text-muted text-sm leading-relaxed">{pillar.desc}</p>
        </div>
      ))}
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 animate-on-scroll">
      {[
        { count: '7', suffix: '+', label: 'Años de experiencia' },
        { count: '50', suffix: '+', label: 'Proyectos completados' },
        { count: '30', suffix: '+', label: 'Clientes satisfechos' },
        { count: '99', suffix: '%', label: 'Uptime garantizado' },
      ].map(stat => (
        <div class="text-center p-6">
          <span class="text-4xl md:text-5xl font-black text-primary stat-number" data-count={stat.count} data-suffix={stat.suffix}>0</span>
          <span class="block text-text-muted text-sm mt-2">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
