---
export const prerender = false;

import { verifySession } from '../api/auth';
import IntranetLayout from '../../layouts/IntranetLayout.astro';

const session = verifySession(Astro.cookies.get('sc_session')?.value);
const isAuth = session.valid;
const user = session.user || '';
---

{isAuth ? (
<IntranetLayout title="Dashboard" activePage="dashboard">
  <!-- KPI Cards -->
  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="kpi-icon" style="color:var(--teal)"><i class="bi bi-robot"></i></div>
      <div class="kpi-value" id="kpiAgents">0</div>
      <div class="kpi-label">Agentes Activos</div>
      <div class="kpi-accent" style="background:var(--teal)"></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="color:var(--violet)"><i class="bi bi-lightning-charge"></i></div>
      <div class="kpi-value" id="kpiTasks">0</div>
      <div class="kpi-label">Tareas Hoy</div>
      <div class="kpi-accent" style="background:var(--violet)"></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="color:var(--blue)"><i class="bi bi-people"></i></div>
      <div class="kpi-value" id="kpiLeads">0</div>
      <div class="kpi-label">Leads Nuevos</div>
      <div class="kpi-accent" style="background:var(--blue)"></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="color:var(--amber)"><i class="bi bi-calendar-check"></i></div>
      <div class="kpi-value" id="kpiMeetings">0</div>
      <div class="kpi-label">Reuniones</div>
      <div class="kpi-accent" style="background:var(--amber)"></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="color:var(--green)"><i class="bi bi-rocket-takeoff"></i></div>
      <div class="kpi-value" id="kpiDeploy" style="font-size:0.95rem">—</div>
      <div class="kpi-label">Último Deploy</div>
      <div class="kpi-accent" style="background:var(--green)"></div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon" style="color:var(--orange)"><i class="bi bi-coin"></i></div>
      <div class="kpi-value" id="kpiTokens">0</div>
      <div class="kpi-label">Tokens IA Hoy</div>
      <div class="kpi-accent" style="background:var(--orange)"></div>
    </div>
  </div>

  <!-- Charts Row -->
  <div class="grid-60-40" style="margin-bottom:1.5rem">
    <div class="card">
      <div class="card-header">
        <h3><i class="bi bi-activity"></i> Actividad 7 días</h3>
      </div>
      <div class="card-body">
        <div class="chart-container" style="height:220px">
          <canvas id="activityChart"></canvas>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header">
        <h3><i class="bi bi-pie-chart"></i> Tareas por Agente</h3>
      </div>
      <div class="card-body">
        <div class="chart-container" style="height:220px">
          <canvas id="agentDonut"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Agents Table + Live Feed -->
  <div class="grid-60-40" style="margin-bottom:1.5rem">
    <div class="card">
      <div class="card-header">
        <h3><i class="bi bi-robot"></i> Agentes IA — Estado</h3>
        <a href="/intranet/agents" class="btn btn-sm">Ver todos <i class="bi bi-arrow-right"></i></a>
      </div>
      <div class="card-body" style="padding:0">
        <table class="data-table">
          <thead>
            <tr><th>Agente</th><th>Modelo</th><th>Estado</th><th>Tareas</th><th>Última act.</th></tr>
          </thead>
          <tbody id="agentsTableBody">
            <tr><td colspan="5" class="empty-state"><p>Cargando...</p></td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div class="card">
      <div class="card-header">
        <h3><i class="bi bi-terminal"></i> Live Feed</h3>
      </div>
      <div class="card-body" style="padding:0">
        <div class="terminal" id="liveFeed" style="border:none;border-radius:0;max-height:280px">
          <div class="log-line"><span class="log-time">--:--:--</span><span class="log-tag info">INFO</span><span class="log-msg">Esperando actividad...</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Deploy Panel -->
  <div class="card">
    <div class="card-header">
      <h3><i class="bi bi-rocket-takeoff"></i> Deploy Rápido</h3>
      <div style="display:flex;gap:0.5rem">
        <button class="btn btn-primary btn-sm" onclick="triggerDeploy('all')"><i class="bi bi-play-fill"></i> Deploy Todo</button>
        <button class="btn btn-sm" onclick="triggerDeploy('vercel')"><i class="bi bi-triangle-fill" style="font-size:0.5rem"></i> Vercel</button>
        <button class="btn btn-orange btn-sm" onclick="triggerDeploy('aws')"><i class="bi bi-cloud"></i> AWS</button>
      </div>
    </div>
    <div class="card-body" style="padding:0">
      <div class="terminal" id="deployLog" style="border:none;border-radius:0;max-height:160px">
        <div class="log-line"><span class="log-time">--:--:--</span><span class="log-tag info">INFO</span><span class="log-msg">Listo para deploy</span></div>
      </div>
    </div>
  </div>

  <script is:inline>
    var agentColors = {
      claude: { color: '#00e5b0', icon: 'bi-robot' },
      groq: { color: '#f59e0b', icon: 'bi-cpu' },
      grok: { color: '#8b5cf6', icon: 'bi-lightning-charge' },
      gemini: { color: '#22c55e', icon: 'bi-gem' },
      deployer: { color: '#3b82f6', icon: 'bi-gear-wide-connected' },
    };

    function api(payload) {
      return fetch('/api/agents', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      }).then(function(r) { return r.json(); });
    }

    // --- Load Dashboard ---
    function refreshPage() {
      loadAgents();
      loadLogs();
      loadKpis();
    }

    function loadAgents() {
      api({ action: 'list' }).then(function(d) {
        if (!d.agents) return;
        var agents = d.agents;
        var active = agents.filter(function(a) { return a.active; }).length;
        var totalTasks = agents.reduce(function(s, a) { return s + (a.tasks_count || 0); }, 0);
        document.getElementById('kpiAgents').textContent = active;
        document.getElementById('kpiTasks').textContent = totalTasks;
        document.getElementById('kpiDeploy').textContent = new Date().toLocaleDateString('es-CL');

        // Agents table
        var tbody = document.getElementById('agentsTableBody');
        tbody.innerHTML = agents.map(function(a) {
          var c = agentColors[a.agent_id] || { color: '#94a3b8', icon: 'bi-cpu' };
          var statusClass = a.active ? 'badge-green' : 'badge-amber';
          var statusText = a.active ? 'Activo' : 'Standby';
          return '<tr>' +
            '<td><span style="color:' + c.color + '"><i class="bi ' + c.icon + '"></i></span> ' + (a.name || a.agent_id) + '</td>' +
            '<td class="mono">' + (a.model || '—') + '</td>' +
            '<td><span class="badge-pill ' + statusClass + '"><span class="dot dot-' + (a.active ? 'active' : 'standby') + '" style="width:6px;height:6px"></span> ' + statusText + '</span></td>' +
            '<td>' + (a.tasks_count || 0) + '</td>' +
            '<td class="mono" style="font-size:0.65rem">' + (a.updated_at ? new Date(a.updated_at).toLocaleString('es-CL', {hour:'2-digit',minute:'2-digit'}) : '—') + '</td>' +
            '</tr>';
        }).join('');

        // Donut chart
        renderDonut(agents);
      });
    }

    function loadLogs() {
      var ids = ['claude', 'groq', 'grok', 'gemini', 'deployer'];
      Promise.all(ids.map(function(id) { return api({ action: 'logs', agentId: id }); }))
        .then(function(results) {
          var allLogs = [];
          results.forEach(function(r) { if (r.logs) allLogs = allLogs.concat(r.logs); });
          allLogs.sort(function(a, b) { return new Date(b.created_at) - new Date(a.created_at); });
          renderLiveFeed(allLogs.slice(0, 15));
        });
    }

    function loadKpis() {
      api({ action: 'query', table: 'leads', limit: 1000 }).then(function(d) {
        if (d.data) document.getElementById('kpiLeads').textContent = d.data.length;
      }).catch(function(){});
      api({ action: 'query', table: 'reuniones', limit: 1000 }).then(function(d) {
        if (d.data) document.getElementById('kpiMeetings').textContent = d.data.length;
      }).catch(function(){});
    }

    function renderLiveFeed(logs) {
      var feed = document.getElementById('liveFeed');
      if (!logs || logs.length === 0) return;
      feed.innerHTML = logs.map(function(l) {
        var time = l.created_at ? new Date(l.created_at).toLocaleTimeString('es-CL', {hour:'2-digit',minute:'2-digit',second:'2-digit'}) : '--:--:--';
        var tagClass = l.status === 'error' ? 'error' : (l.action === 'toggle' ? 'info' : 'build');
        var agent = (l.agent_name || l.agent_id || '').toUpperCase().substring(0, 6);
        return '<div class="log-line"><span class="log-time">' + time + '</span><span class="log-tag ' + tagClass + '">' + agent + '</span><span class="log-msg">' + (l.detail || l.action || '').substring(0, 80) + '</span></div>';
      }).join('');
      feed.scrollTop = feed.scrollHeight;
    }

    function renderDonut(agents) {
      var canvas = document.getElementById('agentDonut');
      if (!canvas || typeof Chart === 'undefined') return;
      var existing = Chart.getChart(canvas);
      if (existing) existing.destroy();

      var labels = agents.map(function(a) { return a.name || a.agent_id; });
      var data = agents.map(function(a) { return a.tasks_count || 1; });
      var colors = agents.map(function(a) { return (agentColors[a.agent_id] || {}).color || '#475569'; });

      new Chart(canvas, {
        type: 'doughnut',
        data: { labels: labels, datasets: [{ data: data, backgroundColor: colors, borderWidth: 0, hoverOffset: 6 }] },
        options: {
          cutout: '65%',
          plugins: {
            legend: { position: 'bottom', labels: { padding: 12, font: { size: 11 } } },
          },
        },
      });
    }

    // Activity chart (mock data for now)
    function renderActivityChart() {
      var canvas = document.getElementById('activityChart');
      if (!canvas || typeof Chart === 'undefined') return;
      var existing = Chart.getChart(canvas);
      if (existing) existing.destroy();

      var days = [];
      for (var i = 6; i >= 0; i--) {
        var d = new Date(); d.setDate(d.getDate() - i);
        days.push(d.toLocaleDateString('es-CL', { weekday: 'short' }));
      }

      new Chart(canvas, {
        type: 'line',
        data: {
          labels: days,
          datasets: [
            { label: 'Leads', data: [2, 1, 3, 0, 4, 2, 1], borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.08)', fill: true, tension: 0.4, pointRadius: 3, borderWidth: 2 },
            { label: 'Tareas', data: [5, 3, 8, 2, 6, 4, 3], borderColor: '#00e5b0', backgroundColor: 'rgba(0,229,176,0.08)', fill: true, tension: 0.4, pointRadius: 3, borderWidth: 2 },
          ],
        },
        options: {
          scales: {
            x: { grid: { display: false } },
            y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.04)' } },
          },
          plugins: { legend: { position: 'top', align: 'end' } },
          interaction: { intersect: false, mode: 'index' },
        },
      });
    }

    // Deploy trigger
    function triggerDeploy(target) {
      var log = document.getElementById('deployLog');
      var now = new Date().toLocaleTimeString('es-CL', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
      log.innerHTML += '<div class="log-line new"><span class="log-time">' + now + '</span><span class="log-tag push">DEPLOY</span><span class="log-msg">Disparando deploy ' + target + '...</span></div>';
      log.scrollTop = log.scrollHeight;

      api({ action: 'execute', agentId: 'deployer', prompt: 'Deploy ' + target, taskType: 'general' })
        .then(function(d) {
          var t = new Date().toLocaleTimeString('es-CL', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
          var tag = d.success ? 'ok' : 'error';
          var msg = d.success ? 'Deploy disparado via GitHub Actions' : (d.error || d.result || 'Error');
          log.innerHTML += '<div class="log-line new"><span class="log-time">' + t + '</span><span class="log-tag ' + tag + '">' + tag.toUpperCase() + '</span><span class="log-msg">' + msg + '</span></div>';
          log.scrollTop = log.scrollHeight;
        });
    }

    // Polling
    var pollInterval;
    function startPolling() { refreshPage(); pollInterval = setInterval(refreshPage, 10000); }
    function stopPolling() { clearInterval(pollInterval); }
    document.addEventListener('visibilitychange', function() {
      document.hidden ? stopPolling() : startPolling();
    });

    // Init
    startPolling();
    setTimeout(renderActivityChart, 300);
  </script>
</IntranetLayout>
) : (
<!-- Login Screen -->
<html lang="es-CL">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Smart Connection — Intranet</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="shortcut icon" href="/img/smart.ico">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --teal: #00e5b0; --teal-dim: rgba(0,229,176,0.12); --bg: #0a0d14; --bg2: #111827; --text: #f1f5f9; --muted: #94a3b8; }
    body { font-family: 'Inter', system-ui, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1rem; }
    .login-card { background: rgba(17,24,39,0.8); backdrop-filter: blur(20px); border: 1px solid rgba(0,229,176,0.12); border-radius: 20px; padding: 3rem; max-width: 400px; width: 100%; text-align: center; }
    .login-card img { height: 40px; margin-bottom: 1.5rem; }
    .login-card h1 { font-size: 1.3rem; font-weight: 800; margin-bottom: 0.4rem; }
    .login-card p { color: var(--muted); font-size: 0.8rem; margin-bottom: 2rem; }
    .pin-container { display: flex; justify-content: center; gap: 0.75rem; margin-bottom: 1.5rem; }
    .pin-digit { width: 56px; height: 64px; background: rgba(255,255,255,0.04); border: 2px solid rgba(255,255,255,0.08); border-radius: 14px; color: #fff; font-size: 1.5rem; font-weight: 800; text-align: center; outline: none; transition: all 0.2s; caret-color: var(--teal); }
    .pin-digit:focus { border-color: var(--teal); background: var(--teal-dim); box-shadow: 0 0 24px rgba(0,229,176,0.15); }
    .pin-digit.filled { border-color: var(--teal); }
    .pin-digit.error { border-color: #ef4444; animation: shake 0.4s ease; }
    .pin-digit.success { border-color: #22c55e; background: rgba(34,197,94,0.1); }
    .pin-status { font-size: 0.75rem; color: var(--muted); min-height: 1.5rem; }
    .pin-status.error { color: #ef4444; }
    .pin-status.success { color: #22c55e; }
    @keyframes shake { 0%,100% { transform: translateX(0); } 25% { transform: translateX(-8px); } 75% { transform: translateX(8px); } }
  </style>
</head>
<body>
  <div class="login-card">
    <img src="/img/logo_smart.svg" alt="Smart Connection">
    <h1>Intranet</h1>
    <p>Ingresa tu PIN de acceso</p>
    <div class="pin-container" id="pinContainer">
      <input type="password" class="pin-digit" maxlength="1" autocomplete="off" data-index="0">
      <input type="password" class="pin-digit" maxlength="1" autocomplete="off" data-index="1">
      <input type="password" class="pin-digit" maxlength="1" autocomplete="off" data-index="2">
      <input type="password" class="pin-digit" maxlength="1" autocomplete="off" data-index="3">
    </div>
    <div class="pin-status" id="pinStatus"><i class="bi bi-shield-lock"></i> 4 caracteres</div>
  </div>
  <script is:inline>
    var pinDigits = document.querySelectorAll('.pin-digit');
    var pinStatus = document.getElementById('pinStatus');
    var pinLocked = false;
    if (pinDigits.length) pinDigits[0].focus();

    pinDigits.forEach(function(input, idx) {
      input.addEventListener('input', function() {
        var val = this.value.replace(/[^0-9a-zA-Z]/g, '');
        this.value = val ? val[0] : '';
        if (this.value) {
          this.classList.add('filled');
          if (idx < pinDigits.length - 1) pinDigits[idx + 1].focus();
          var pin = '';
          pinDigits.forEach(function(d) { pin += d.value; });
          if (pin.length === 4 && !pinLocked) { pinLocked = true; pinStatus.innerHTML = '<i class="bi bi-hourglass-split"></i> Verificando...'; submitPin(pin); }
        } else { this.classList.remove('filled'); }
      });
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Backspace' && !this.value && idx > 0) { pinDigits[idx - 1].focus(); pinDigits[idx - 1].value = ''; pinDigits[idx - 1].classList.remove('filled'); }
      });
      input.addEventListener('paste', function(e) {
        e.preventDefault();
        var pasted = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9a-zA-Z]/g, '');
        for (var i = 0; i < Math.min(pasted.length, 4); i++) { pinDigits[i].value = pasted[i]; pinDigits[i].classList.add('filled'); }
        if (pasted.length >= 4 && !pinLocked) { pinLocked = true; pinStatus.innerHTML = '<i class="bi bi-hourglass-split"></i> Verificando...'; submitPin(pasted.substring(0, 4)); }
      });
    });

    function submitPin(pin) {
      fetch('/api/auth', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ pin: pin }) })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(res) {
          if (res.ok && res.data.success) {
            pinDigits.forEach(function(d) { d.classList.add('success'); });
            pinStatus.innerHTML = '<i class="bi bi-check-circle"></i> Bienvenido';
            pinStatus.className = 'pin-status success';
            setTimeout(function() { window.location.reload(); }, 500);
          } else {
            pinDigits.forEach(function(d) { d.classList.add('error'); d.value = ''; });
            pinStatus.innerHTML = '<i class="bi bi-x-circle"></i> PIN incorrecto';
            pinStatus.className = 'pin-status error';
            setTimeout(function() { pinDigits.forEach(function(d) { d.classList.remove('error', 'filled'); }); pinStatus.innerHTML = '<i class="bi bi-shield-lock"></i> 4 caracteres'; pinStatus.className = 'pin-status'; pinLocked = false; pinDigits[0].focus(); }, 1500);
          }
        })
        .catch(function() { pinStatus.innerHTML = '<i class="bi bi-x-circle"></i> Error'; pinStatus.className = 'pin-status error'; pinLocked = false; });
    }
  </script>
</body>
</html>
)}
